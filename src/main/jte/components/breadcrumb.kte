@param items: List<kotlin.Pair<String, String?>>

<nav style="font-size:0.8rem; color:var(--bt-muted); margin-bottom:1.5rem; display:flex; align-items:center; gap:0.375rem; flex-wrap:wrap;">
    @for(item in items)
        @if(item.second != null)
            <a href="${item.second}" style="color:var(--bt-accent-dim); text-decoration:none;"
                onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">${item.first}</a>
            <i class="ri-arrow-right-s-line" style="font-size:0.7rem; color:var(--bt-muted);"></i>
        @else
            <span style="color:var(--bt-text); font-weight:500;">${item.first}</span>
        @endif
    @endfor
</nav>
