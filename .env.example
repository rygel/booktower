# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Long random string used to sign JWTs. Generate with:
#   openssl rand -base64 48
BOOKTOWER_JWT_SECRET=change-me-to-a-long-random-string

# MariaDB passwords
MARIADB_ROOT_PASSWORD=change-me-root-password
MARIADB_PASSWORD=change-me-booktower-password

# Comma-separated list of hostnames that are allowed to make state-changing
# requests (CSRF protection). Add your domain or reverse-proxy hostname.
BOOKTOWER_CSRF_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.example.com

# ── Optional ──────────────────────────────────────────────────────────────────

# MariaDB username (default: booktower)
# MARIADB_USER=booktower

# Port to expose on the host (default: 9999)
# BOOKTOWER_PORT=9999

# Enable quickstart mode: creates a demo user + library on first run.
# Set to true only for a first-run demo; disable afterwards.
# BOOKTOWER_QUICKSTART=true
