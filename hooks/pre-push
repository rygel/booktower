#!/bin/bash
# BookTower pre-push hook — runs the full test suite before every push.
# Bypass with:  git push --no-verify

set -euo pipefail

echo ""
echo "=== BookTower pre-push: running tests ==="
echo ""

if mvn test --no-transfer-progress -q; then
    echo ""
    echo "=== All tests passed — pushing ==="
    echo ""
    exit 0
else
    echo ""
    echo "=== Tests FAILED — push blocked ==="
    echo "    Fix the failures above, then push again."
    echo "    To skip: git push --no-verify"
    echo ""
    exit 1
fi
