# BookTower — Environment Variables
# Copy this file to .env and fill in the values.

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BOOKTOWER_JWT_SECRET=change-me-to-a-long-random-string
DB_PASSWORD=change-me-to-a-strong-password

# ── Domain ────────────────────────────────────────────────────────────────────
BOOKTOWER_DOMAIN=books.example.com
BOOKTOWER_BASE_URL=https://books.example.com

# ── Registration ──────────────────────────────────────────────────────────────
REGISTRATION_OPEN=true

# ── SMTP (optional — for password reset emails and book delivery) ─────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── OIDC / SSO (optional — uncomment and configure to enable) ────────────────
# OIDC_ISSUER=https://auth.example.com/realms/booktower
# OIDC_CLIENT_ID=booktower
# OIDC_CLIENT_SECRET=
# OIDC_FORCE_ONLY=false
# OIDC_ADMIN_GROUP_PATTERN=^booktower-admin$

# ── Metadata Providers (optional) ────────────────────────────────────────────
HARDCOVER_API_KEY=
COMICVINE_API_KEY=
