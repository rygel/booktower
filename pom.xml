        <!-- SonarQube Properties (Override via -D or settings.xml) -->
        <sonar.host.url>http://localhost:9000</sonar.host.url>
        <sonar.projectKey>org.runary:runary</sonar.projectKey>
        <sonar.projectName>Runary</sonar.projectName>

        <!-- Logging Versions -->
        <slf4j.version>2.0.17</slf4j.version>
        <logback.version>1.5.32</logback.version>

        <!-- Other Versions -->
        <jackson.version>2.21.2</jackson.version>
        <jackson-kotlin.version>2.21.2</jackson-kotlin.version>
        <jwt.version>4.5.1</jwt.version>
        <bcrypt.version>0.4</bcrypt.version>
        <pdfbox.version>3.0.7</pdfbox.version>
