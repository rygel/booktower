        <errorprone.version>2.48.0</errorprone.version>
        <spotless.version>3.4.0</spotless.version>
        <ktlint.version>3.5.0</ktlint.version>
        <sonar-scanner.version>5.5.0.6356</sonar-scanner.version>
        <duplicate-finder.version>2.0.1</duplicate-finder.version>
