<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude JTE generated code from analysis -->
    <Match>
        <Class name="~gg\.jte\.generated\..*" />
    </Match>

    <!--
        Kotlin compiler false positives — these patterns are generated by the Kotlin
        compiler and cannot be fixed at the source level without restructuring idiomatic
        Kotlin code.
    -->

    <!-- BC_BAD_CAST_TO_ABSTRACT_COLLECTION:
         The Kotlin compiler generates ArrayList/LinkedHashMap instances typed as List/Map.
         SpotBugs sees these as casts to abstract types. The Kotlin type system statically
         proves these are safe; there is no source fix without rewriting idiomatic Kotlin. -->
    <Match>
        <Bug pattern="BC_BAD_CAST_TO_ABSTRACT_COLLECTION" />
        <Package name="~org\.runary\..*" />
    </Match>

    <!-- BX_UNBOXING_IMMEDIATELY_REBOXED:
         Kotlin's boxing/unboxing interop with Java generics is handled by the compiler.
         These patterns are correct and there is no source-level fix. -->
    <Match>
        <Bug pattern="BX_UNBOXING_IMMEDIATELY_REBOXED" />
        <Package name="~org\.runary\..*" />
    </Match>

    <!-- SA_LOCAL_SELF_ASSIGNMENT:
         The Kotlin compiler emits self-assignments in smart-cast and destructuring
         generated bytecode. Not fixable at the source level. -->
    <Match>
        <Bug pattern="SA_LOCAL_SELF_ASSIGNMENT" />
        <Package name="~org\.runary\..*" />
    </Match>

    <!-- OBL_UNSATISFIED_OBLIGATION / OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE:
         Kotlin's 'use {}' extension reliably closes resources. SpotBugs cannot follow
         the inline closure and misidentifies it as a potential resource leak. -->
    <Match>
        <Or>
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION" />
            <Bug pattern="OBL_UNSATISFIED_OBLIGATION_EXCEPTION_EDGE" />
        </Or>
        <Package name="~org\.runary\..*" />
    </Match>

    <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2 / MS_EXPOSE_REP:
         In this project all handler/service fields are immutable, DI-managed singletons.
         SpotBugs cannot distinguish singleton service references from mutable collection
         fields. Kotlin data class componentN() functions and DI constructors generate
         these warnings unavoidably. -->
    <Match>
        <Or>
            <Bug pattern="EI_EXPOSE_REP" />
            <Bug pattern="EI_EXPOSE_REP2" />
            <Bug pattern="MS_EXPOSE_REP" />
        </Or>
        <Package name="~org\.runary\..*" />
    </Match>

    <!-- REC_CATCH_EXCEPTION:
         Kotlin's runCatching{} and http4k request handlers legitimately catch Exception
         as a top-level safety net. Narrowing to specific subtypes would miss unexpected
         runtime failures from the framework. -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION" />
        <Package name="~org\.runary\..*" />
    </Match>

    <!-- NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE:
         Kotlin null-safety smart-casts prove non-null at compile time in cases where
         SpotBugs' inter-procedural analysis reports a possible null path. -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
        <Package name="~org\.runary\..*" />
    </Match>

    <!-- SR_NOT_CHECKED:
         InputStream.read() return value — the http4k framework and the JVM IO layer
         guarantee full reads in the contexts used here (readBytes(), ByteArray copy). -->
    <Match>
        <Bug pattern="SR_NOT_CHECKED" />
        <Package name="~org\.runary\..*" />
    </Match>
    <!-- BookLinkService: intentional fallback for when both books have same format -->
    <Match>
        <Class name="org.runary.services.BookLinkService" />
        <Bug pattern="DB_DUPLICATE_BRANCHES" />
    </Match>
</FindBugsFilter>
